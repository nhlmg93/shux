# syntax=docker/dockerfile:1.7
# shux test bed: Alpine + Go, real libghostty-vt (see Makefile libghostty).
# Build:  docker build -f Dockerfile.sim.env -t shux-test .
# Run:   docker run --rm --name shux-test-run shux-test   (see Makefile test-docker)
# Or:   make test-docker
#
# Pin the Go line to your go.mod as needed. Uses Alpine-based official Go image.
FROM golang:1.24-alpine

ENV TZ=UTC
ENV CGO_ENABLED=1
# go.mod may require a newer Go than the base image; download toolchain to match.
ENV GOTOOLCHAIN=auto
ENV PATH=/usr/local/go/bin:$PATH

# Toolchain for zig (Ghostty lib-vt), cgo (go-libghostty), and the repo Makefile.
RUN apk add --no-cache \
	make git ca-certificates \
	zig build-base \
	pkgconf \
	gcc musl-dev linux-headers

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

# Build libghostty before copying the whole repo. This keeps the expensive
# Ghostty/lib-vt layer cached across normal source-only test changes.
COPY Makefile ./
RUN --mount=type=cache,target=/root/.cache/zig \
	make libghostty

COPY . ./

# Same layout as the Makefile’s PREFIX; useful for ad-hoc go test in the container.
ENV PKG_CONFIG_PATH=/src/.deps/prefix/lib/pkgconfig:/src/.deps/prefix/share/pkgconfig

CMD ["sh", "-lc", "CGO_ENABLED=1 PKG_CONFIG_PATH=/src/.deps/prefix/lib/pkgconfig:/src/.deps/prefix/share/pkgconfig /usr/local/go/bin/go test -count=1 -shuffle=off ./test/sim/..."]
