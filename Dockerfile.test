# E2E test environment - Alpine Linux
# Builds shux with embedded libghostty, includes nano/vim for testing
FROM golang:1.26-alpine

RUN apk add --no-cache git zig gcc g++ musl-dev pkgconfig nano vim less

WORKDIR /shux

# Build Ghostty VT once in a source-independent layer so normal code changes
# don't force a full Zig rebuild every test run.
RUN rm -rf ghostty-build && \
    mkdir -p ghostty-build/usr/lib/pkgconfig ghostty-build/usr/include && \
    git clone --depth=1 https://github.com/ghostty-org/ghostty.git ghostty-build/ghostty && \
    cd ghostty-build/ghostty && \
    zig build -Doptimize=ReleaseFast -Demit-lib-vt=true && \
    cp zig-out/lib/libghostty-vt.a ../usr/lib/libghostty-vt-static.a && \
    cp -r include/ghostty ../usr/include/ && \
    printf '%s\n' \
      'prefix=/shux/ghostty-build/usr' \
      'exec_prefix=${prefix}' \
      'libdir=${prefix}/lib' \
      'includedir=${prefix}/include' \
      '' \
      'Name: libghostty-vt-static' \
      'Description: Ghostty VT static library' \
      'Version: 0' \
      'Libs: -L${libdir} -lghostty-vt-static' \
      'Cflags: -I${includedir}' \
      > ../usr/lib/pkgconfig/libghostty-vt-static.pc && \
    rm -rf /shux/ghostty-build/ghostty

ENV SHUX_E2E=1
ENV PKG_CONFIG_PATH=/shux/ghostty-build/usr/lib/pkgconfig

# Copy and download deps first for better Go module caching.
COPY go.mod go.sum ./
RUN go mod download

# Copy source last so code changes invalidate only the small final layer.
COPY . .

CMD ["go", "test", "./...", "-v", "-count=1"]
