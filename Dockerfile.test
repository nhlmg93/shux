# E2E test environment - Alpine Linux
# Builds shux with embedded libghostty, includes nano/vim for testing
FROM golang:1.26-alpine

ARG GHOSTTY_REF=dcc39dcd401975ee77a642fa15ba7bb9f6d85b96

RUN apk add --no-cache git zig gcc g++ musl-dev pkgconfig nano vim less bash

WORKDIR /shux

# Copy the Ghostty build helper first so normal source changes don't invalidate
# the expensive Zig layer.
COPY scripts/build-ghostty-vt.sh /usr/local/bin/build-ghostty-vt.sh
RUN chmod +x /usr/local/bin/build-ghostty-vt.sh

# Build Ghostty VT once in a source-independent layer so normal code changes
# don't force a full Zig rebuild every test run.
RUN GHOSTTY_REF=${GHOSTTY_REF} /usr/local/bin/build-ghostty-vt.sh /shux/ghostty-build/usr

ENV SHUX_E2E=1
ENV PKG_CONFIG_PATH=/shux/ghostty-build/usr/lib/pkgconfig

# Copy and download deps first for better Go module caching.
COPY go.mod go.sum ./
RUN go mod download

# Copy source last so code changes invalidate only the small final layer.
COPY . .

CMD ["go", "test", "./...", "-v", "-count=1"]
